# ─── SpeakEasy environment variables ────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# ── Firebase Auth ─────────────────────────────────────────────────────────────
# 1. Go to https://console.firebase.google.com
# 2. Create a project → Add a web app
# 3. Copy config values from "Your apps → Firebase SDK snippet"
# 4. Enable Authentication → Sign-in method → Email/Password + Email link
VITE_FIREBASE_API_KEY=AIzaSyB5JBfl4BCnZLgEh4_Z24epk3p-2FhogWk
VITE_FIREBASE_AUTH_DOMAIN=ypolis-270d0.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=polis-270d0
VITE_FIREBASE_APP_ID=1:591603082922:web:a65a3464afec5bff53d2d3

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Create a project at https://app.revenuecat.com
# Dashboard → iOS app → API keys → Public SDK key
VITE_RC_IOS_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Dashboard → Android app → API keys → Public SDK key
VITE_RC_ANDROID_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# The entitlement identifier you created in RevenueCat
VITE_RC_ENTITLEMENT=premium
# The offering identifier (usually "default")
VITE_RC_OFFERING=default

# ── Trial period ──────────────────────────────────────────────────────────────
# Number of days of full access after account creation (grace period).
# Defaults to 7 in code if not set.
VITE_TRIAL_DAYS=7

# ── Formspree ─────────────────────────────────────────────────────────────────
# Create forms at https://formspree.io and paste only the form ID (after /f/).
# If FEEDBACK is omitted, it falls back to the CONTACT form.
VITE_FORMSPREE_CONTACT_ID=xeoqgpnv
VITE_FORMSPREE_FEEDBACK_ID=

# ── Developer bypass ──────────────────────────────────────────────────────────
# Set to "true" during local development to skip the paywall entirely.
# This ONLY works when Vite runs in development mode (npm run dev).
# Production builds always ignore this flag.
VITE_DEV_SUBSCRIPTION_OVERRIDE=true

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set to "true" to run the app in restricted showcase / demo mode.
# Disables: AI, Listen mode, subscription/paywall, trial counter, login/signup.
# Default: false (everything works normally).
VITE_DEMO=false
